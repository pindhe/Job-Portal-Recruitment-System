# Copy to .env and adjust for your environment
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (defaults to SQLite if not set). For MySQL set these:
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=jobportal
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=3306

# Email (console backend by default in DEBUG)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@jobportal.local

# Integrations (placeholders for service layer)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
OPENAI_API_KEY=
